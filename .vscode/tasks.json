{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "SlyTranslate: Build Plugin ZIP",
            "type": "shell",
            "command": "bash",
            "args": [
                ".github/scripts/build-plugin-zip.sh",
                "${workspaceFolder}/slytranslate.zip"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "presentation": {
                "reveal": "always",
                "panel": "shared",
                "clear": true
            },
            "problemMatcher": []
        },
        {
            "label": "SlyTranslate: Verify Plugin ZIP",
            "type": "shell",
            "command": "bash",
            "args": [
                ".github/scripts/verify-plugin-zip.sh",
                "${workspaceFolder}/slytranslate.zip"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "presentation": {
                "reveal": "always",
                "panel": "shared",
                "clear": true
            },
            "problemMatcher": []
        },
        {
            "label": "SlyTranslate: Build and Verify Plugin ZIP",
            "dependsOrder": "sequence",
            "dependsOn": [
                "SlyTranslate: Build Plugin ZIP",
                "SlyTranslate: Verify Plugin ZIP"
            ],
            "problemMatcher": []
        },
        {
            "label": "SlyTranslate: Sync changelog.txt from CHANGELOG.md",
            "type": "shell",
            "command": "bash",
            "args": [
                ".github/scripts/sync-changelog-txt.sh"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "presentation": {
                "reveal": "always",
                "panel": "shared",
                "clear": true
            },
            "problemMatcher": []
        },
        {
            "label": "SlyTranslate: Deploy Plugin ZIP to WordPress Pod",
            "type": "shell",
            "command": "bash",
            "args": [
                ".github/scripts/deploy-plugin-to-wordpress-pod.sh",
                "${workspaceFolder}/slytranslate.zip"
            ],
            "options": {
                "cwd": "${workspaceFolder}",
                "env": {
                    "SLYTRANSLATE_DEPLOY_NAMESPACE": "default",
                    "SLYTRANSLATE_DEPLOY_POD_SELECTOR": "app.kubernetes.io/instance=wp-loco,app.kubernetes.io/name=wordpress",
                    "SLYTRANSLATE_DEPLOY_CONTAINER": "wordpress",
                    "SLYTRANSLATE_KUBECTL_BIN": "/opt/homebrew/bin/kubectl"
                }
            },
            "dependsOrder": "sequence",
            "dependsOn": [
                "SlyTranslate: Verify Plugin ZIP"
            ],
            "presentation": {
                "reveal": "always",
                "panel": "shared",
                "clear": true
            },
            "problemMatcher": []
        },
        {
            "label": "SlyTranslate: Build and Deploy Plugin ZIP",
            "dependsOrder": "sequence",
            "dependsOn": [
                "SlyTranslate: Build Plugin ZIP",
                "SlyTranslate: Deploy Plugin ZIP to WordPress Pod"
            ],
            "problemMatcher": []
        }
    ]
}
