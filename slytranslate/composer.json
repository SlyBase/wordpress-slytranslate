{
  "name": "slybase/slytranslate",
  "description": "AI translation abilities for WordPress",
  "type": "wordpress-plugin",
  "license": "MIT",
  "require": {
    "php": ">=8.1"
  },
  "require-dev": {
    "phpunit/phpunit": "^10.5"
  },
  "autoload": {
    "psr-4": {
      "SlyTranslate\\": "inc/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "SlyTranslate\\Tests\\": "tests/"
    }
  },
  "scripts": {
    "test": "vendor/bin/phpunit",
    "test:unit": "vendor/bin/phpunit --testsuite unit"
  },
  "config": {
    "allow-plugins": {
      "dealerdirect/phpcodesniffer-composer-installer": true
    }
  }
}